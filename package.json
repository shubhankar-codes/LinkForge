  "keywords": [
    "url-shortener",
    "analytics",
    "nodejs",
    "express",
    "postgresql",
    "redis"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "ua-parser-js": "^1.0.37",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^25.0.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
