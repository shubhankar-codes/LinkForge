{
  "name": "snapurl",
  "version": "0.1.0",
  "description": "A modern URL shortener with analytics, conditional redirects, and link-in-bio pages",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js",
    "db:migrate": "psql -U postgres -f schema.sql"
